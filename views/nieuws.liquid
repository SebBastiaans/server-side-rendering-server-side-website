{%  render 'partials/head.liquid' %}

<header class="header-nieuws">
    <h1>Veld nieuws</h1>

    <ul class="nieuws-sort">
        <li><a href="">Laatste</a></li>
        <li><a href="">In de bloei</a></li>
        <li><a href="">Na de bloei</a></li>
    </ul>

    <form action="" method="GET">
        <img src="" alt="Zoek icoon">
        <input type="search" name="search" placeholder="Zoek">
    </form>
</header>

<main class="main-nieuws">
    <ul>
        {% for newsItem in news %}
            <li>
                <img src="https://fdnd-agency.directus.app/assets/{{newsItem.image}}" alt="{{newsItem.title}}">
                <p>Bloemneveld</p> 
                <a href="">
                    {{ newsItem.title }}
                </a>
            </li> 
        {% endfor %}

    </ul>
</main>

{%  render 'partials/navbar.liquid' %}

{%  render 'partials/foot.liquid' %}

